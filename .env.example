# Setup-Agent (SAG) environment configuration example
# Copy this file as .env and fill in actual values.

# ==================== Model Configuration ====================
# Thinking model configuration (analysis / planning role).
# Supported providers include openai, anthropic, deepseek, ollama, and ollama_chat.
SAG_THINKING_MODEL=gpt-5.4-mini
SAG_THINKING_PROVIDER=openai
SAG_THINKING_TEMPERATURE=1
SAG_MAX_THINKING_TOKENS=16000

# Generic reasoning effort for OpenAI o-series, Anthropic adaptive thinking,
# and DeepSeek reasoner models.
SAG_REASONING_EFFORT=medium

# GPT-5 specific reasoning effort. Used for GPT-5 models in either role.
SAG_GPT5_REASONING_EFFORT=medium

# Fixed-budget Anthropic thinking fallback for pre-adaptive Claude models.
# Claude 4.6/4.7 use SAG_REASONING_EFFORT instead.
SAG_THINKING_BUDGET_TOKENS=10000

# Action model configuration (tool invocation role).
SAG_ACTION_MODEL=gpt-5
SAG_ACTION_PROVIDER=openai
SAG_ACTION_TEMPERATURE=1
SAG_MAX_ACTION_TOKENS=10000

# ==================== API Keys ====================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional providers
# GROQ_API_KEY=your_groq_api_key_here
# AZURE_API_KEY=your_azure_api_key_here

# ==================== API Base URLs ====================
# OpenAI API base URL (useful if using a proxy or custom endpoint).
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama base URL for SAG_*_PROVIDER=ollama or ollama_chat.
OLLAMA_BASE_URL=http://localhost:11434

# Azure API configuration
# AZURE_API_BASE=your_azure_api_base_here
# AZURE_API_VERSION=2023-12-01-preview

# ==================== Logging Configuration ====================
# Log level: DEBUG, INFO, WARNING, ERROR
SAG_LOG_LEVEL=INFO
SAG_LOG_FILE=logs/sag.log
SAG_VERBOSE=false
SAG_UI_MODE=false
SAG_LOG_ROTATION=50 MB
SAG_LOG_RETENTION=30 days

# ==================== Docker Configuration ====================
SAG_DOCKER_BASE_IMAGE=ubuntu:24.04
SAG_WORKSPACE_PATH=/workspace

# ==================== Agent Configuration ====================
SAG_MAX_ITERATIONS=50
SAG_CONTEXT_SWITCH_THRESHOLD=20

# ==================== Model Selection Notes ====================
# GPT-5.4 mini thinking role:
#   SAG_THINKING_MODEL=gpt-5.4-mini
#   SAG_THINKING_PROVIDER=openai
#   SAG_GPT5_REASONING_EFFORT=medium
#
# GPT-5 in either role:
#   SAG_THINKING_MODEL=gpt-5
#   SAG_THINKING_PROVIDER=openai
#   SAG_ACTION_MODEL=gpt-5
#   SAG_ACTION_PROVIDER=openai
#
# Claude 4.6 thinking role:
#   SAG_THINKING_MODEL=claude-sonnet-4-6
#   SAG_THINKING_PROVIDER=anthropic
#   SAG_REASONING_EFFORT=medium
#
# DeepSeek reasoner thinking role:
#   SAG_THINKING_MODEL=deepseek-reasoner
#   SAG_THINKING_PROVIDER=deepseek
#   SAG_REASONING_EFFORT=medium
#
# Ollama chat action role:
#   SAG_ACTION_MODEL=llama3.1
#   SAG_ACTION_PROVIDER=ollama_chat
#   OLLAMA_BASE_URL=http://localhost:11434
